# ============================================================
# Harmoniq Safety — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ============================================================

# ----------------------------------------------------------
# Supabase (Required)
# ----------------------------------------------------------
# Project URL from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key (server-side only — NEVER expose with NEXT_PUBLIC_ prefix)
# Required for: initial setup, user invitations, health check DB probe
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----------------------------------------------------------
# Site URL (Required)
# ----------------------------------------------------------
# The canonical URL of your deployed site (no trailing slash)
# Used for OAuth redirects, invitation links, and CSRF origin checks
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------
# Sentry Error Tracking (Optional — recommended for production)
# ----------------------------------------------------------
# DSN from Sentry dashboard > Settings > Client Keys
NEXT_PUBLIC_SENTRY_DSN=

# Auth token for source map uploads during build (CI/CD only)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ----------------------------------------------------------
# Cloudflare Turnstile CAPTCHA (Optional — for contact form)
# ----------------------------------------------------------
# Site key (public) and secret key (server-side)
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ----------------------------------------------------------
# Platform Configuration (Optional)
# ----------------------------------------------------------
# Comma-separated company slugs reserved for platform admin
# These slugs cannot be used by regular companies
NEXT_PUBLIC_PLATFORM_SLUGS=platform,admin,superadmin

# Support contact info shown in platform admin settings
NEXT_PUBLIC_SUPPORT_EMAIL=support@harmoniq.io
NEXT_PUBLIC_SUPPORT_URL=https://support.harmoniq.io

# ----------------------------------------------------------
# Development Mode (Optional — NEVER enable in production)
# ----------------------------------------------------------
# Set to "true" to run without Supabase (uses localStorage + mock data)
# NEXT_PUBLIC_ENABLE_MOCK_MODE=true
